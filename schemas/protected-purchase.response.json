{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/CivilisAI/Civilis-Risk-OS/schemas/protected-purchase.response.json",
  "title": "ProtectedPurchaseResponse",
  "type": "object",
  "required": ["success", "purchaseMode", "protectedPurchaseId"],

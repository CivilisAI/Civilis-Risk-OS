    "intelPurchaseId": { "type": ["integer", "null"], "minimum": 1 },
    "principalAcpJobId": { "type": ["integer", "null"], "minimum": 1 },
    "challengeDeadline": { "type": ["string", "null"] },
    "content": {}
  },
  "additionalProperties": true
}
